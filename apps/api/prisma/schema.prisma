// AEM Residence Operations - Prisma schema
// SQLite for local dev (no Docker). Production can use PostgreSQL by changing provider + url.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Tenant. Tenant-owned rows carry an organizationId FK back to here.
// organizationId is nullable for now (expand phase): all existing rows are
// backfilled into a default org, and once writes set it (org-context task) a
// follow-up migration contracts it to NOT NULL.
model Organization {
  id             String   @id @default(uuid())
  name           String
  slug           String   @unique // URL-safe tenant key, e.g. "aem-residence"
  logoUrl        String?
  invoiceName    String? // legal name shown on invoices/PDFs (may differ from name)
  invoiceAddress String?
  invoiceEmail   String?
  invoicePhone   String?
  invoiceRegNo   String? // company registration number (e.g. "Mat. Br. ...")
  currency       String   @default("MKD") // ISO 4217, e.g. MKD, EUR
  locale         String   @default("mk") // en | mk | sq
  mkdToEurRate   Float    @default(61.5) // MKD per 1 EUR; used by the cost calculator
  plan           String   @default("FREE") // FREE | PRO | ENTERPRISE (extensible)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  users              User[]
  suppliers          Supplier[]
  products           Product[]
  orders             Order[]
  orderItems         OrderItem[]
  reconciliations    Reconciliation[]
  inventoryMovements InventoryMovement[]
  invitations        Invitation[]
}

// Pending teammate invite. The admin generates a shareable link carrying `token`;
// the invitee opens it, sets a password, and joins this org with `role`.
model Invitation {
  id             String       @id @default(uuid())
  email          String
  role           String       @default("VIEWER") // ADMIN | MANAGER | VIEWER
  token          String       @unique
  status         String       @default("PENDING") // PENDING | ACCEPTED | REVOKED
  expiresAt      DateTime
  acceptedAt     DateTime?
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@index([organizationId])
  @@index([token])
}

model User {
  id             String       @id @default(uuid())
  email          String       @unique
  passwordHash   String
  role           String       @default("ADMIN") // extensible: ADMIN, MANAGER, VIEWER
  organizationId String // every user belongs to an org (NOT NULL); other tenant models stay nullable during expand/contract
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  passwordResetTokens PasswordResetToken[]

  @@index([organizationId])
}

// Password reset token. Auth infra keyed by token (accessed while logged out),
// so it is NOT a tenant-scoped model — it is reached via its unique token.
model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([token])
}

// HTTP session store (via @quixo3/prisma-session-store). Sessions live in the DB
// instead of local files, so they survive restarts and are shared across
// instances. Not tenant-scoped.
model Session {
  id        String   @id
  sid       String   @unique
  data      String
  expiresAt DateTime

  @@index([expiresAt])
}

model Supplier {
  id             String        @id @default(uuid())
  companyName    String
  contactPerson  String?
  phone          String?
  location       String?
  status         String        @default("ACTIVE") // ACTIVE | INACTIVE
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  orders         Order[]

  @@index([organizationId])
}

model Product {
  id                 String              @id @default(uuid())
  name               String
  category           String
  measurementUnit    String // kg, ton, litre, adet, m, m², m³, torba, paket, kutu, rulo
  price              Float
  status             String              @default("ACTIVE") // ACTIVE | INACTIVE
  organizationId     String?
  organization       Organization?       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  inventoryMovements InventoryMovement[]

  @@index([organizationId])
}

model InventoryMovement {
  id               String        @id @default(uuid())
  productId        String
  type             String // ORDER_CREATE | ORDER_CANCEL | RECONCILE_ADJUST | MANUAL_ADJUST | STOCK_IN
  deltaQty         Int // negative = usage, positive = restock
  reason           String?
  orderId          String?
  reconciliationId String?
  organizationId   String?
  organization     Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt        DateTime      @default(now())
  product          Product       @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([createdAt])
  @@index([organizationId])
}

model Order {
  id             String          @id @default(uuid())
  orderNumber    String          @unique // ORD-{shortId}
  orderDate      DateTime
  supplierId     String
  supplierName   String // snapshot at order time
  totalAmount    Float
  status         String          @default("PENDING") // PENDING | DELIVERED | RECONCILED
  notes          String?
  organizationId String?
  organization   Organization?   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  supplier       Supplier        @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  orderItems     OrderItem[]
  reconciliation Reconciliation?

  @@index([organizationId])
}

model OrderItem {
  id                  String               @id @default(uuid())
  orderId             String
  productId           String? // nullable if product deleted
  name                String // snapshot
  unit                String // snapshot
  price               Float // snapshot
  quantity            Int
  organizationId      String?
  organization        Organization?        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  order               Order                @relation(fields: [orderId], references: [id], onDelete: Cascade)
  reconciliationItems ReconciliationItem[]

  @@index([organizationId])
}

model Reconciliation {
  id                 String               @id @default(uuid())
  orderId            String               @unique
  reconciliationDate DateTime             @default(now())
  notes              String?
  totalLossValue     Float
  organizationId     String?
  organization       Organization?        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt          DateTime             @default(now())
  order              Order                @relation(fields: [orderId], references: [id], onDelete: Cascade)
  items              ReconciliationItem[]

  @@index([organizationId])
}

model ReconciliationItem {
  id               String         @id @default(uuid())
  reconciliationId String
  orderItemId      String
  orderItem        OrderItem      @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  name             String // snapshot
  unit             String // snapshot
  price            Float // snapshot
  orderedQty       Int
  receivedQty      Int
  missingQty       Int // max(orderedQty - receivedQty, 0)
  lossValue        Float
  status           String // COMPLETE | MISSING | EXCESS
  reconciliation   Reconciliation @relation(fields: [reconciliationId], references: [id], onDelete: Cascade)
}
